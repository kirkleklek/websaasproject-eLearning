# ===========================================
# RAILWAY ENVIRONMENT VARIABLES
# ===========================================
# Copy nilai-nilai ini ke Railway Dashboard:
# Project Settings → Variables
# ===========================================

# --- APPLICATION ---
APP_NAME="WIB Learning"
APP_ENV=production
APP_DEBUG=false

# ⚠️ GENERATE BARU dengan: php artisan key:generate --show
APP_KEY=base64:GENERATE_BARU_DENGAN_PHP_ARTISAN_KEY_GENERATE_SHOW

# Railway akan auto-inject URL, tapi bisa set manual jika perlu
# APP_URL=https://your-app.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
BCRYPT_ROUNDS=12

# --- LOGGING ---
LOG_CHANNEL=stack
LOG_LEVEL=error

# --- DATABASE (Railway PostgreSQL) ---
# Railway auto-inject dari PostgreSQL service, tinggal reference:
DB_CONNECTION=pgsql
DB_HOST=${PGHOST}
DB_PORT=${PGPORT}
DB_DATABASE=${PGDATABASE}
DB_USERNAME=${PGUSER}
DB_PASSWORD=${PGPASSWORD}

# --- SESSION & CACHE ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- FILESYSTEM ---
FILESYSTEM_DISK=public

# --- MAIL ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@wib.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- BROADCAST ---
BROADCAST_CONNECTION=log
